{
  "name": "museum_access_control",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "node server.js",
    "build": "vite build",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql",
    "db:access-user": "psql \"$DATABASE_URL\" -f db/access-user.sql",
    "db:reset": "psql \"$DATABASE_URL\" -f db/schema.sql && psql \"$DATABASE_URL\" -f db/seed.sql",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.19"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
